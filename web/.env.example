# Console web da loja (Next.js) — copie para .env.local e preencha.
#
# LOCAL: use os valores impressos por `supabase status` (na raiz do projeto).
#   NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<publishable/anon local>
#
# PRODUÇÃO (Vercel): defina estas como Environment Variables no projeto Vercel,
# com os valores do projeto HOSTED (Supabase Dashboard → Project Settings → API):
#   NEXT_PUBLIC_SUPABASE_URL=https://nkmpxyumayvnbpwxdkke.supabase.co
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<publishable key do hosted>

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Segredo para invalidação on-demand do cache (mesmo valor em WEB_APP_URL + REVALIDATE_SECRET nas Edge Functions)
REVALIDATE_SECRET=
