# Secrets das Edge Functions (Pix via Asaas)
# Copie para supabase/functions/.env (gitignored) e preencha ASAAS_API_KEY.
# Carregue com: supabase functions serve --env-file supabase/functions/.env
#
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY são injetadas
# automaticamente pelo runtime — NÃO precisa colocar aqui.

# Chave de API do Asaas (sandbox). Painel: sandbox.asaas.com → Integrações → API
ASAAS_API_KEY=PREENCHA_COM_SUA_CHAVE_SANDBOX

# Base do Asaas (sandbox por padrão; troque para produção quando for o caso)
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3

# Token compartilhado do webhook (defina o MESMO valor no painel do Asaas).
ASAAS_WEBHOOK_TOKEN=troque-por-um-token-aleatorio
